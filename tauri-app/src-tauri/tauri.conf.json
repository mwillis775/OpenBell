{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/tauri-v2/src-tauri/gen/schemas/desktop-schema.json",
  "productName": "OpenBell",
  "version": "1.0.0",
  "identifier": "com.openbell.dashboard",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "OpenBell",
        "width": 1200,
        "height": 800,
        "minWidth": 480,
        "minHeight": 360,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src * data: blob:; media-src * data: blob:; connect-src 'self' http: https: ws: wss:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon-32.png",
      "icons/icon-128.png",
      "icons/icon.png"
    ]
  }
}
